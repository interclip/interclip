APP_RELEASE=development
APP_COMMIT=
APP_BRANCH=main

IP_HASH_KEY=devcontainer-local-ip-hash-key-not-for-production

AUTH_TYPE=mock
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_DOMAIN=
AUTH0_COOKIE_SECRET=devcontainer-local-cookie-secret-not-for-production

FILE_UPLOAD_ENABLED=false
