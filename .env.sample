# DB stuff
DB_NAME=iclip
DB_SERVER=127.0.0.1:3306 # The host to connect to
PASSWORD=
USERNAME=interclip

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_KEY_PREFIX=interclip-development
RATE_LIMIT_FAIL_CLOSED=false
TRUSTED_PROXIES=
CLIP_RATE_LIMIT=15
CLIP_RATE_WINDOW=30
CLIP_READ_RATE_LIMIT=30
CLIP_READ_RATE_WINDOW=60

# General
ENVIRONMENT=development # Can be one of: 'production', 'development' or 'staging'
PROTOCOL=http # The protocol used to connect to the server. Can be either 'HTTP' or 'HTTPS'
ROOT= # The root of your webserver. It is used for dynamiocally changing the location of assets
APP_URL=http://localhost:8080 # Public origin. HTTPS is required in production
APP_RELEASE=
APP_COMMIT=
APP_BRANCH=main

# IP hashing
IP_HASH_KEY=

# AUTH0
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_DOMAIN=
AUTH0_COOKIE_SECRET=

AUTH_TYPE=mock # The authentication type, can be either 'mock' or 'account'. If set to 'account', you need to set the Auth0 authentication, too

# The presigner supports anonymous uploads. Set the token only if the upstream requires Bearer authentication.
# Pin the exact S3-compatible hostname returned by the presigner before enabling uploads.
FILE_UPLOAD_ENABLED=false
FILES_API_TOKEN=
FILES_UPLOAD_HOST=

# Sentry
SENTRY_URL=
TRACES_SAMPLE_RATE=0.0 # Explicitly opt in to performance tracing after reviewing data handling

# Rclone
RCLONE_REMOTE_NAME=
