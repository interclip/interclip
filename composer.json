{
  "name": "interclip/interclip",
  "description": "A clipboard and file sharing tool",
  "license": "MIT",
  "require-dev": {
    "pestphp/pest": "^3.8",
    "squizlabs/php_codesniffer": "^3.13"
  },
  "require": {
    "php": "^8.2",
    "ext-curl": "*",
    "ext-mysqli": "*",
    "ext-redis": "*",
    "vlucas/phpdotenv": "^5.6",
    "auth0/auth0-php": "^8.19",
    "guzzlehttp/guzzle": "^7.12.1",
    "sentry/sdk": "^4.0",
    "tracy/tracy": "^2.10",
    "league/uri-interfaces": "^7.8"
  },
  "config": {
    "platform": {
      "php": "8.2.0"
    },
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
